{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(#{1,3}|={1,3}|\\+{1,3})\\s",
      "end": "^(?=\\s*(#{1,3}|={1,3}|\\+{1,3})\\s)"
    }
  },
  "wordPattern": "(@[\\w-]+|[\\w-]+)"
}
