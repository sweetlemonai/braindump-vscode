      "settings": {
        "foreground": "#b85289",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.section.3.bd",
      "settings": {
        "foreground": "#a96589",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.list.unnumbered.bd",
      "settings": {
        "foreground": "#b34d8c"
      }
    },
    {
      "scope": "markup.list.unnumbered.2.bd",
      "settings": {
        "foreground": "#a95c8c"
