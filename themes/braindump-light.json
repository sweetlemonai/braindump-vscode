{
  "name": "Braindump Light",
  "type": "light",
  "colors": {
    "editor.background": "#fdfdfb",
    "editor.foreground": "#24292e",
    "editor.lineHighlightBackground": "#f4f4f0",
    "editorLineNumber.foreground": "#8a8a8a",
    "editorCursor.foreground": "#24292e"
  },
  "tokenColors": [
    {
      "scope": "markup.heading.1.bd",
      "settings": {
        "foreground": "#b85f0a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.2.bd",
      "settings": {
        "foreground": "#ad6a2a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.3.bd",
      "settings": {
        "foreground": "#a1754a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "punctuation.definition.heading.bd",
      "settings": {
        "foreground": "#8a8a8a"
      }
    },
    {
      "scope": "markup.heading.category.bd",
      "settings": {
        "foreground": "#5e3aa7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.category.2.bd",
      "settings": {
        "foreground": "#694ea0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.category.3.bd",
      "settings": {
        "foreground": "#746299",
        "fontStyle": "bold"
      }
    },
    {
