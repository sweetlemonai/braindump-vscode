        "foreground": "#2e7e54",
        "fontStyle": "bold italic"
      }
    },
    {
      "scope": "keyword.other.annotation.question.3.bd",
      "settings": {
        "foreground": "#4d8266",
        "fontStyle": "bold italic"
      }
    },
    {
      "scope": [
        "markup.other.callout.important.line.bd",
