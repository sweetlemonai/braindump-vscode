      "scope": "keyword.other.command.in.2.bd",
      "settings": {
        "foreground": "#5a6992"
      }
    },
    {
      "scope": "keyword.other.command.in.3.bd",
      "settings": {
        "foreground": "#6a748f"
      }
    },
    {
      "scope": [
        "meta.mention.line.bd",
        "variable.other.mention.bd"
      ],
      "settings": {
        "foreground": "#8a4ad4"
      }
    },
    {
      "scope": "comment.line.double-slash.bd",
      "settings": {
        "foreground": "#6a737d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "punctuation.definition.comment.bd",
      "settings": {
        "foreground": "#8a8a8a"
      }
    },
    {
      "scope": [
        "string.quoted.double.bd",
        "string.quoted.single.bd"
      ],
      "settings": {
        "foreground": "#6b5d00"
      }
    },
    {
      "scope": "markup.inline.raw.bd",
      "settings": {
        "foreground": "#145a32"
      }
    },
    {
      "scope": [
        "punctuation.definition.string.bd",
        "punctuation.definition.raw.bd"
      ],
      "settings": {
        "foreground": "#8a8a8a"
      }
    },
    {
      "scope": "variable.other.key.bd",
      "settings": {
        "foreground": "#2d7a88"
      }
    },
    {
      "scope": "punctuation.separator.key-value.bd",
      "settings": {
        "foreground": "#8a8a8a"
      }
    },
    {
      "scope": "string.unquoted.value.bd",
      "settings": {
        "foreground": "#24292e"
      }
    },
    {
      "scope": "markup.list.numbered.bd",
      "settings": {
        "foreground": "#3a3a3a"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.numbered.bd",
      "settings": {
        "foreground": "#8a8a8a"
      }
    },
    {
      "scope": "markup.list.alpha.bd",
      "settings": {
        "foreground": "#b34d8c"
      }
    },
    {
      "scope": "meta.parens.line.bd",
      "settings": {
        "foreground": "#8a5a2b"
      }
    },
    {
      "scope": "meta.brackets.line.bd",
      "settings": {
        "foreground": "#6a4096"
      }
    },
    {
      "scope": "meta.braces.line.bd",
      "settings": {
        "foreground": "#2d7a3a"
      }
    },
    {
      "scope": "markup.underline.link.bd",
      "settings": {
        "foreground": "#0366d6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.other.underscore.bd",
      "settings": {
        "foreground": "#767778",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.other.double-underscore.bd",
      "settings": {
        "foreground": "#767778",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character.escape.bd",
      "settings": {
        "foreground": "#8a8a8a"
      }
    }
  ],
  "semanticTokenColors": {}
}
