// SYNTAX TEST "source.bd" "quoted and backtick strings"

lorem "ipsum" dolor
//    ^ punctuation.definition.string.bd
//    ^^^^^^^ string.quoted.double.bd
//          ^ punctuation.definition.string.bd

lorem 'ipsum' dolor
//    ^ punctuation.definition.string.bd
//    ^^^^^^^ string.quoted.single.bd
//          ^ punctuation.definition.string.bd

lorem `ipsum` dolor
//    ^ punctuation.definition.raw.bd
//    ^^^^^^^ markup.inline.raw.bd
//          ^ punctuation.definition.raw.bd

mixed "double" and 'single' and `backtick` on one line
//    ^^^^^^^^ string.quoted.double.bd
//                 ^^^^^^^^ string.quoted.single.bd
//                              ^^^^^^^^^^ markup.inline.raw.bd

Email foo@bar.com (shouldn't bleed into the next line).
//                        ^ - string.quoted.single.bd
This line is prose and must not be scoped as a string.
// <- - string.quoted.single.bd

Unclosed "quote on one line
//        ^^^^^^^^^^^^^^^^^ string.quoted.double.bd
next line is prose again
// <- - string.quoted.double.bd

Unclosed `backtick likewise
//       ^^^^^^^^^^^^^^^^^^ markup.inline.raw.bd
and again prose
// <- - markup.inline.raw.bd

I don't think the apostrophe should open a string
// <- - string.quoted.single.bd
//   ^ - string.quoted.single.bd
//        ^ - string.quoted.single.bd

what's up, let's go
//  ^ - string.quoted.single.bd
//          ^ - string.quoted.single.bd

5'9" measurements stay plain
// <- - string.quoted.single.bd
// <- - string.quoted.double.bd
