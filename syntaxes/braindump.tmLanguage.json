{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Braindump",
  "scopeName": "source.braindump",
  "fileTypes": ["bd"],
  "patterns": [
    { "include": "#code-block" },
    { "include": "#comment" },
    { "include": "#heading" },
    { "include": "#category" },
    { "include": "#section" },
    { "include": "#question" },
    { "include": "#alert" },
    { "include": "#forward" },
    { "include": "#brace-line" },
    { "include": "#paren-line" },
    { "include": "#task" },
    { "include": "#bracket-line" },
    { "include": "#list-numbered" },
    { "include": "#list-lettered" },
    { "include": "#bullet" },
    { "include": "#priority" },
    { "include": "#back" },
    { "include": "#key-value" },
    { "include": "#inline-overlays" }
  ],
  "repository": {
    "inline-overlays": {
      "patterns": [
        { "include": "#string" },
        { "include": "#url" },
        { "include": "#flag" },
        { "include": "#mention-line" },
        { "include": "#mention-word" }
      ]
    },

    "code-block": {
      "patterns": [
        { "include": "#code-block-typescript" },
        { "include": "#code-block-javascript" },
        { "include": "#code-block-python" },
        { "include": "#code-block-json" },
        { "include": "#code-block-bash" },
        { "include": "#code-block-html" },
        { "include": "#code-block-css" },
        { "include": "#code-block-sql" },
        { "include": "#code-block-yaml" },
        { "include": "#code-block-markdown" },
        { "include": "#code-block-plain" }
      ]
    },

    "code-block-typescript": {
      "begin": "^(```)(typescript|ts)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.typescript",
          "patterns": [{ "include": "source.ts" }]
        }
      ]
    },

    "code-block-javascript": {
      "begin": "^(```)(javascript|js)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.javascript",
          "patterns": [{ "include": "source.js" }]
        }
      ]
    },

    "code-block-python": {
      "begin": "^(```)(python|py)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.python",
          "patterns": [{ "include": "source.python" }]
        }
      ]
    },

    "code-block-json": {
      "begin": "^(```)(json)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.json",
          "patterns": [{ "include": "source.json" }]
        }
      ]
    },

    "code-block-bash": {
      "begin": "^(```)(bash|sh|shell|zsh)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.shell",
          "patterns": [{ "include": "source.shell" }]
        }
      ]
    },

    "code-block-html": {
      "begin": "^(```)(html)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.html",
          "patterns": [{ "include": "text.html.basic" }]
        }
      ]
    },

    "code-block-css": {
      "begin": "^(```)(css)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.css",
          "patterns": [{ "include": "source.css" }]
        }
      ]
    },

    "code-block-sql": {
      "begin": "^(```)(sql)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.sql",
          "patterns": [{ "include": "source.sql" }]
        }
      ]
    },

    "code-block-yaml": {
      "begin": "^(```)(yaml|yml)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.yaml",
          "patterns": [{ "include": "source.yaml" }]
        }
      ]
    },

    "code-block-markdown": {
      "begin": "^(```)(markdown|md)\\s*$",
      "end": "^(```)\\s*$",
      "name": "markup.raw.block.braindump",
      "patterns": [
        {
          "begin": "(^|\\G)",
          "while": "(^|\\G)(?!\\s*```\\s*$)",
          "contentName": "meta.embedded.block.markdown",
          "patterns": [{ "include": "text.html.markdown" }]
        }
      ]
    },

    "code-block-plain": {
      "begin": "^```[\\w-]*\\s*$",
      "end": "^```\\s*$",
      "name": "markup.raw.block.braindump"
    },

    "comment": {
      "match": "^\\s*//(?!/).*$",
      "name": "comment.line.double-slash.braindump"
    },

    "heading": {
      "patterns": [
        {
          "begin": "^\\s*#{3}(?=\\s|$)",
          "end": "$",
          "name": "markup.heading.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*#{2}(?=\\s|$)",
          "end": "$",
          "name": "markup.heading.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*#{1}(?=\\s|$)",
          "end": "$",
          "name": "markup.heading.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "category": {
      "patterns": [
        {
          "begin": "^\\s*={3}(?=\\s|$)",
          "end": "$",
          "name": "markup.category.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*={2}(?=\\s|$)",
          "end": "$",
          "name": "markup.category.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*={1}(?=\\s|$)",
          "end": "$",
          "name": "markup.category.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "section": {
      "patterns": [
        {
          "begin": "^\\s*\\+{3}(?=\\s|$)",
          "end": "$",
          "name": "markup.section.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*\\+{2}(?=\\s|$)",
          "end": "$",
          "name": "markup.section.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*\\+{1}(?=\\s|$)",
          "end": "$",
          "name": "markup.section.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "question": {
      "patterns": [
        {
          "begin": "^\\s*\\?{3}(?=\\s|$)",
          "end": "$",
          "name": "markup.question.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*\\?{2}(?=\\s|$)",
          "end": "$",
          "name": "markup.question.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*\\?{1}(?=\\s|$)",
          "end": "$",
          "name": "markup.question.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "alert": {
      "begin": "^\\s*!(?=\\s|$)",
      "end": "$",
      "name": "markup.alert.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "forward": {
      "patterns": [
        {
          "begin": "^\\s*>{3}(?=\\s)",
          "end": "$",
          "name": "markup.forward.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*>{2}(?=\\s)",
          "end": "$",
          "name": "markup.forward.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*>{1}(?=\\s)",
          "end": "$",
          "name": "markup.forward.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "brace-line": {
      "match": "^\\s*\\{[^{}]*\\}\\s*$",
      "name": "markup.brace.line.braindump"
    },

    "paren-line": {
      "match": "^\\s*(\\()([^()]*)(\\))\\s*$",
      "name": "markup.paren.line.braindump",
      "captures": {
        "1": { "name": "punctuation.paren.line.braindump" },
        "2": { "name": "markup.paren.line.content.braindump" },
        "3": { "name": "punctuation.paren.line.braindump" }
      }
    },

    "bracket-line": {
      "match": "^\\s*(\\[)([^\\[\\]]*)(\\])",
      "name": "markup.bracket.line.braindump",
      "captures": {
        "1": { "name": "punctuation.bracket.line.braindump" },
        "2": { "name": "markup.bracket.line.content.braindump" },
        "3": { "name": "punctuation.bracket.line.braindump" }
      }
    },

    "task": {
      "match": "^\\s*(\\[)([ xX])(\\])(?=\\s|$)",
      "captures": {
        "1": { "name": "markup.task.bracket.braindump" },
        "2": { "name": "markup.task.bracket.braindump" },
        "3": { "name": "markup.task.bracket.braindump" }
      }
    },

    "list-numbered": {
      "begin": "^\\s*\\d+\\.(?=\\s)",
      "end": "$",
      "name": "markup.list.numbered.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "list-lettered": {
      "begin": "^\\s*[A-Za-z]\\.(?=\\s)",
      "end": "$",
      "name": "markup.list.lettered.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "bullet": {
      "patterns": [
        {
          "match": "^\\s*(-{3})(?=\\s)",
          "captures": { "1": { "name": "keyword.bullet.depth-3.braindump" } }
        },
        {
          "match": "^\\s*(-{2})(?=\\s)",
          "captures": { "1": { "name": "keyword.bullet.depth-2.braindump" } }
        },
        {
          "match": "^\\s*(-{1})(?=\\s)",
          "captures": { "1": { "name": "keyword.bullet.depth-1.braindump" } }
        }
      ]
    },

    "priority": {
      "patterns": [
        {
          "begin": "^\\s*(\\*{3})(?=\\s)",
          "beginCaptures": { "1": { "name": "keyword.priority.depth-3.braindump" } },
          "end": "$",
          "name": "markup.priority.line.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*(\\*{2})(?=\\s)",
          "beginCaptures": { "1": { "name": "keyword.priority.depth-2.braindump" } },
          "end": "$",
          "name": "markup.priority.line.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*(\\*{1})(?=\\s)",
          "beginCaptures": { "1": { "name": "keyword.priority.depth-1.braindump" } },
          "end": "$",
          "name": "markup.priority.line.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "back": {
      "patterns": [
        {
          "begin": "^\\s*<{3}(?=\\s)",
          "end": "$",
          "name": "keyword.back.depth-3.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*<{2}(?=\\s)",
          "end": "$",
          "name": "keyword.back.depth-2.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        },
        {
          "begin": "^\\s*<{1}(?=\\s)",
          "end": "$",
          "name": "keyword.back.depth-1.braindump",
          "patterns": [{ "include": "#inline-overlays" }]
        }
      ]
    },

    "key-value": {
      "patterns": [
        { "include": "#kv-arrow-fat" },
        { "include": "#kv-arrow-thin" },
        { "include": "#kv-equals" },
        { "include": "#kv-colon" }
      ]
    },

    "kv-colon": {
      "begin": "^\\s*([\\p{L}][\\p{L}\\p{N}_-]*(?: [\\p{L}\\p{N}_-]+)*)\\s*(:)\\s+",
      "beginCaptures": {
        "1": { "name": "keyword.field.braindump" },
        "2": { "name": "punctuation.separator.colon.braindump" }
      },
      "end": "$",
      "contentName": "meta.field.value.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "kv-equals": {
      "begin": "^\\s*([\\p{L}][\\p{L}\\p{N}_-]*(?: [\\p{L}\\p{N}_-]+)*)\\s+(=)\\s+",
      "beginCaptures": {
        "1": { "name": "keyword.field.equals.braindump" },
        "2": { "name": "punctuation.separator.equals.braindump" }
      },
      "end": "$",
      "contentName": "meta.field.value.equals.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "kv-arrow-fat": {
      "begin": "^\\s*([\\p{L}][\\p{L}\\p{N}_-]*(?: [\\p{L}\\p{N}_-]+)*)\\s+(=>)\\s+",
      "beginCaptures": {
        "1": { "name": "keyword.field.arrow.braindump" },
        "2": { "name": "punctuation.separator.arrow.braindump" }
      },
      "end": "$",
      "contentName": "meta.field.value.arrow.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "kv-arrow-thin": {
      "begin": "^\\s*([\\p{L}][\\p{L}\\p{N}_-]*(?: [\\p{L}\\p{N}_-]+)*)\\s+(->)\\s+",
      "beginCaptures": {
        "1": { "name": "keyword.field.dash-arrow.braindump" },
        "2": { "name": "punctuation.separator.dash-arrow.braindump" }
      },
      "end": "$",
      "contentName": "meta.field.value.dash-arrow.braindump",
      "patterns": [{ "include": "#inline-overlays" }]
    },

    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.braindump"
    },

    "url": {
      "match": "(?<![\\w/])https?://[^\\s)\\]]+",
      "name": "markup.underline.link.braindump"
    },

    "flag": {
      "match": "(?<!\\S)--[A-Za-z][\\w-]*(?:=\\S+)?",
      "name": "keyword.flag.braindump"
    },

    "mention-line": {
      "begin": "(?<!\\S)@(?=\\s)",
      "end": "$",
      "name": "keyword.mention.braindump",
      "patterns": [
        {
          "match": "//(?!/).*$",
          "name": "comment.line.double-slash.braindump"
        }
      ]
    },

    "mention-word": {
      "match": "(?<!\\S)@[\\p{L}\\p{N}][\\p{L}\\p{N}_-]*",
      "name": "keyword.mention.braindump"
    }
  }
}
