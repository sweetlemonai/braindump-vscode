{
  "name": "braindump-language",
  "displayName": "Braindump",
  "description": "Syntax highlighting for the Braindump note-taking syntax (.bd files).",
  "version": "1.2.0",
  "publisher": "sweet-lemon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "braindump",
    "notes",
    "outline",
    "markdown",
    "note-taking",
    "journal",
    "plain-text",
    "markdown"
  ],
  "icon": "images/braindump.png",
  "homepage": "https://github.com/sweetlemonai/braindump-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetlemonai/braindump-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/sweetlemonai/braindump-vscode/issues"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "braindump",
        "aliases": [
          "Braindump",
          "braindump"
        ],
        "extensions": [
          ".bd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "braindump",
        "scopeName": "source.braindump",
        "path": "./syntaxes/braindump.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "braindump.toggleTask",
        "title": "Braindump: Toggle Task"
      }
    ],
    "keybindings": [
      {
        "command": "braindump.toggleTask",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorLangId == braindump && editorTextFocus"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "source.braindump",
            "settings": {
              "foreground": "#C5C2D6"
            }
          },
          {
            "scope": "markup.heading.depth-1.braindump",
            "settings": {
              "foreground": "#E47A0A",
              "fontStyle": ""
            }
          },
          {
            "scope": "markup.heading.depth-2.braindump",
            "settings": {
              "foreground": "#CD6E09",
              "fontStyle": ""
            }
          },
          {
            "scope": "markup.heading.depth-3.braindump",
            "settings": {
              "foreground": "#B66208",
              "fontStyle": ""
            }
          },
          {
            "scope": "markup.category.depth-1.braindump",
            "settings": {
              "foreground": "#249FD0"
            }
          },
          {
            "scope": "markup.category.depth-2.braindump",
            "settings": {
              "foreground": "#208FBB"
            }
          },
          {
            "scope": "markup.category.depth-3.braindump",
            "settings": {
              "foreground": "#1D7FA6"
            }
          },
          {
            "scope": "markup.section.depth-1.braindump",
            "settings": {
              "foreground": "#DD6BA7"
            }
          },
          {
            "scope": "markup.section.depth-2.braindump",
            "settings": {
              "foreground": "#C76096"
            }
          },
          {
            "scope": "markup.section.depth-3.braindump",
            "settings": {
              "foreground": "#B15686"
            }
          },
          {
            "scope": "keyword.bullet.depth-1.braindump",
            "settings": {
              "foreground": "#DB8FEE"
            }
          },
          {
            "scope": "keyword.bullet.depth-2.braindump",
            "settings": {
              "foreground": "#C581D6"
            }
          },
          {
            "scope": "keyword.bullet.depth-3.braindump",
            "settings": {
              "foreground": "#AF72BE"
            }
          },
          {
            "scope": "keyword.priority.depth-1.braindump",
