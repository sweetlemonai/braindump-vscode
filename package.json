          },
          {
            "scope": "markup.forward.depth-3.braindump",
            "settings": {
              "foreground": "#227379"
            }
          },
          {
            "scope": "keyword.back.depth-1.braindump",
            "settings": {
              "foreground": "#5A8AB0"
